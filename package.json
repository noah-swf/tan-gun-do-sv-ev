{
  "name": "tan-gun-do-sv-ev",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "sveltekit-app",
    "studio"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev --workspace=sveltekit-app\" \"npm run dev --workspace=studio\"",
    "format": "prettier --cache --write ."
  },
  "prettier": {
    "plugins": [
      "prettier-plugin-packagejson"
    ],
    "semi": false,
    "singleQuote": true
  },
  "devDependencies": {
    "@portabletext/svelte": "^3.0.1",
    "autoprefixer": "^10.4.21",
    "concurrently": "^9.1.0",
    "postcss": "^8.5.6",
    "prettier": "3.3.3",
    "prettier-plugin-packagejson": "2.5.1",
    "tailwindcss": "^4.1.13"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.1.13"
  }
}
